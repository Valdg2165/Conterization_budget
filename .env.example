# Copy this file to .env and fill in your values. NEVER commit .env

# ── Auth DB ────────────────────────────────────────────────────────────────────
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=changeme_auth
AUTH_DB_NAME=auth_db

# ── Powens DB ──────────────────────────────────────────────────────────────────
POWENS_DB_USER=powens_user
POWENS_DB_PASSWORD=changeme_powens
POWENS_DB_NAME=powens_db

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# ── Powens API credentials (from your Powens developer dashboard) ───────────────
POWENS_CLIENT_ID=your_powens_client_id
POWENS_CLIENT_SECRET=your_powens_client_secret
POWENS_BASE_URL=https://demo.biapi.pro/2.0
POWENS_WEBAUTH_URL=https://webauth.biapi.pro/2.0/auth/webauth

# ── URLs ───────────────────────────────────────────────────────────────────────
# For local dev, use ngrok to expose port 3002 so Powens can reach the callback
CALLBACK_URL=http://localhost:3002/powens/connect/callback
FRONTEND_URL=http://localhost:5173

# ── Docker Hub ─────────────────────────────────────────────────────────────────
DOCKER_HUB_USER=yourdockerhubusername
IMAGE_TAG=latest
